{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "**": {
      "excludeFiles": "**"
    }
  },
  "rewrites": [
    {
      "source": "/process",
      "destination": "https://rzn-hd-uploader-2.onrender.com/process"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
