{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
    ,
    {
      "src": "images/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/process",
      "destination": "https://rzn-hd-uploader-2.onrender.com/process"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
